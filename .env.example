# Copy this file to .env and fill in your key to enable live LLM-generated advice.
# Without a key, the app runs fully offline using rule-based fallback narratives.
#
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Any model slug from https://openrouter.ai/models works, e.g.:
#   anthropic/claude-sonnet-4.5
#   openai/gpt-4o-mini
#   meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Sign-in (Logto) is required by default: with no [auth] block in
# .streamlit/secrets.toml the app stops rather than serving itself to
# everyone. Set this to run locally without configuring sign-in.
# Never set it on a public deployment.
FC_ALLOW_ANONYMOUS=true
