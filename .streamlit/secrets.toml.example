# Copy this file to .streamlit/secrets.toml (gitignored) to enable sign-in.
# Without this section present, the app runs with authentication disabled -
# exactly like OPENROUTER_API_KEY, a missing/absent [auth] section must
# never crash the app, only skip the feature it powers (utils/auth.py).
#
# Values below are for the Logto tenant "AI Financial Coach"
# (https://cloud.logto.io/kqw1ib/applications/glhes5rwqd5jg2d9nt79x).
# client_secret is intentionally left blank here - create a long-lived
# secret in the Logto console (Application > Settings > "Endpoints &
# Credentials") and paste it in locally; never commit a real secret.
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
# Any random, private string - used to sign Streamlit's auth cookie, not a
# Logto credential. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
cookie_secret = "replace-with-a-random-string"
client_id = "glhes5rwqd5jg2d9nt79x"
client_secret = ""
server_metadata_url = "https://kqw1ib.logto.app/oidc/.well-known/openid-configuration"
# REQUIRED for Logto - not optional tuning. Streamlit defaults to
# prompt="select_account" (streamlit/web/server/starlette/starlette_auth_routes.py),
# which Logto rejects at the authorize endpoint with
# "invalid_request / unsupported prompt value requested". The sign-in button
# then appears to do nothing: the user is bounced straight back to the app
# with only a server-side log line. "login" is the OIDC value Logto supports
# for the same intent.
client_kwargs = { prompt = "login" }

# Whatever redirect_uri you use must be registered on the Logto application
# TWICE, in two separate allowlists:
#   1. "Redirect URIs"           - for sign-in
#   2. "Post sign-out redirect URIs" - for sign-out
# The second is easy to miss. Streamlit does not send the app root on logout;
# it deliberately reuses this exact /oauth2callback URI as
# post_logout_redirect_uri (see the comment at starlette_auth_routes.py's
# _get_provider_logout_url: "some providers seem to require URL to be in a
# whitelist - /oauth2callback should be whitelisted"). Registering only the
# bare root means sign-in works but the "Sign out" button lands the user on
# "oidc.invalid_request / post_logout_redirect_uri not registered".
#
# For the deployed app (financialcoach.streamlit.app), set this same
# [auth] block in Streamlit Community Cloud's "Secrets" settings instead,
# with redirect_uri = "https://financialcoach.streamlit.app/oauth2callback"
# (already registered in both allowlists on the Logto application).
